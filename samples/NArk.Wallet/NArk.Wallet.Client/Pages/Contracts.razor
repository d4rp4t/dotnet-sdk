@page "/contracts"
@inject ArkWalletService Ark
@inject WalletState State
@inject IJSRuntime JS
@using NArk.Wallet.Client.Services
@using NArk.Abstractions.Contracts

<div class="page-header">
    <a href="./settings" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <span class="page-title">Contracts</span>
</div>

<div class="px-20">
    @if (_loading)
    {
        <div class="flex-col gap-12">
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
        </div>
    }
    else if (_contracts.Count == 0)
    {
        <div class="empty-state">
            <p>No contracts tracked yet</p>
            <p class="text-secondary" style="font-size:12px;">Contracts appear when you generate receive addresses</p>
        </div>
    }
    else
    {
        <!-- Filter pills -->
        <div style="display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;">
            <button class="pill @(_filter is null ? "pill-info" : "")" style="cursor:pointer;border:none;"
                    @onclick="@(() => _filter = null)">All (@_contracts.Count)</button>
            <button class="pill @(_filter == "active" ? "pill-success" : "")" style="cursor:pointer;border:none;"
                    @onclick="@(() => _filter = "active")">Active (@_contracts.Count(c => c.ActivityState != ContractActivityState.Inactive))</button>
            <button class="pill @(_filter == "inactive" ? "pill-danger" : "")" style="cursor:pointer;border:none;"
                    @onclick="@(() => _filter = "inactive")">Inactive (@_contracts.Count(c => c.ActivityState == ContractActivityState.Inactive))</button>
        </div>

        <div class="flex-col gap-12">
            @foreach (var c in FilteredContracts)
            {
                <div class="glass-card" style="padding:12px 14px;cursor:pointer;" @onclick="@(() => ToggleDetail(c.Script))">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <div style="min-width:0;flex:1;">
                            <div style="display:flex;align-items:center;gap:6px;">
                                <span class="pill @StatePill(c.ActivityState)" style="font-size:8px;">@c.ActivityState</span>
                                <span class="text-secondary" style="font-size:11px;">@c.Type</span>
                            </div>
                            <p class="mono text-secondary" style="font-size:10px;margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                @c.Script[..Math.Min(40, c.Script.Length)]...
                            </p>
                        </div>
                        <span class="text-secondary" style="font-size:10px;flex-shrink:0;margin-left:8px;">
                            @c.CreatedAt.LocalDateTime.ToString("MMM d HH:mm")
                        </span>
                    </div>

                    @if (_expandedScript == c.Script)
                    {
                        <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border-subtle);">
                            <div class="detail-row">
                                <span class="detail-label">Script</span>
                                <div class="address-display" style="font-size:9px;line-height:1.5;max-height:100px;overflow-y:auto;margin-top:4px;">
                                    @c.Script
                                </div>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Type</span>
                                <span class="detail-value">@c.Type</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">State</span>
                                <span class="detail-value">@c.ActivityState</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Created</span>
                                <span class="detail-value">@c.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </div>
                            @if (c.Metadata is { Count: > 0 })
                            {
                                <div class="detail-row">
                                    <span class="detail-label">Metadata</span>
                                    @foreach (var kv in c.Metadata)
                                    {
                                        <p class="mono text-secondary" style="font-size:10px;">@kv.Key: @kv.Value</p>
                                    }
                                </div>
                            }
                            <button class="btn btn-sm btn-secondary mt-8" @onclick:stopPropagation="true"
                                    @onclick="@(() => CopyScript(c.Script))">
                                @(_copiedScript == c.Script ? "Copied!" : "Copy Script")
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private IReadOnlyCollection<ArkContractEntity> _contracts = [];
    private string? _expandedScript;
    private string? _copiedScript;
    private string? _filter;

    private IEnumerable<ArkContractEntity> FilteredContracts => _filter switch
    {
        "active" => _contracts.Where(c => c.ActivityState != ContractActivityState.Inactive),
        "inactive" => _contracts.Where(c => c.ActivityState == ContractActivityState.Inactive),
        _ => _contracts
    };

    protected override async Task OnInitializedAsync()
    {
        if (State.ActiveWalletId is not null)
        {
            try { _contracts = await Ark.GetContracts(State.ActiveWalletId, take: 500); } catch { }
        }
        _loading = false;
    }

    private void ToggleDetail(string script)
        => _expandedScript = _expandedScript == script ? null : script;

    private async Task CopyScript(string script)
    {
        await JS.InvokeVoidAsync("arkade.copyToClipboard", script);
        _copiedScript = script;
        StateHasChanged();
        await Task.Delay(2000);
        _copiedScript = null;
    }

    private static string StatePill(ContractActivityState state) => state switch
    {
        ContractActivityState.Active => "pill-success",
        ContractActivityState.Inactive => "pill-danger",
        _ => "pill-warning"
    };
}
