@page "/vtxos"
@inject ArkWalletService Ark
@inject WalletState State
@inject IJSRuntime JS
@using NArk.Wallet.Client.Services
@using NArk.Abstractions.VTXOs

<div class="page-header">
    <a href="./settings" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <span class="page-title">VTXOs</span>
</div>

<div class="px-20">
    @if (_loading)
    {
        <div class="flex-col gap-12">
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
        </div>
    }
    else if (_vtxos.Count == 0)
    {
        <div class="empty-state">
            <p>No coins yet</p>
            <p class="text-secondary" style="font-size:12px;">Receive funds to create VTXOs</p>
        </div>
    }
    else
    {
        <!-- Summary -->
        <div class="glass-card mb-16" style="padding:12px 14px;">
            <div style="display:flex;justify-content:space-between;">
                <div>
                    <p class="text-secondary" style="font-size:11px;">Live</p>
                    <p style="font-size:16px;font-weight:600;font-family:var(--font-mono);">
                        @_vtxos.Count(v => !v.IsSpent()) <span class="text-secondary" style="font-weight:400;font-size:12px;">coins</span>
                    </p>
                </div>
                <div style="text-align:right;">
                    <p class="text-secondary" style="font-size:11px;">Total</p>
                    <p style="font-size:16px;font-weight:600;font-family:var(--font-mono);">
                        @_vtxos.Where(v => !v.IsSpent()).Aggregate(0UL, (sum, v) => sum + v.Amount).ToString("N0") <span class="text-secondary" style="font-weight:400;font-size:12px;">sats</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Filter -->
        <div style="display:flex;gap:6px;margin-bottom:16px;">
            <button class="pill @(_filter is null ? "pill-info" : "")" style="cursor:pointer;border:none;"
                    @onclick="@(() => _filter = null)">All</button>
            <button class="pill @(_filter == "live" ? "pill-success" : "")" style="cursor:pointer;border:none;"
                    @onclick="@(() => _filter = "live")">Live</button>
            <button class="pill @(_filter == "spent" ? "pill-danger" : "")" style="cursor:pointer;border:none;"
                    @onclick="@(() => _filter = "spent")">Spent</button>
        </div>

        <div class="flex-col gap-12">
            @foreach (var vtxo in FilteredVtxos)
            {
                <div class="glass-card" style="padding:12px 14px;cursor:pointer;" @onclick="@(() => ToggleDetail(vtxo.TransactionId))">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <div>
                            <p style="font-size:14px;font-weight:600;font-family:var(--font-mono);">
                                @vtxo.Amount.ToString("N0") <span class="text-secondary" style="font-weight:400;font-size:12px;">sats</span>
                            </p>
                            <p class="mono text-secondary" style="font-size:10px;">
                                @vtxo.TransactionId[..16]...:@vtxo.TransactionOutputIndex
                            </p>
                        </div>
                        <span class="pill @(vtxo.IsSpent() ? "pill-danger" : "pill-success")" style="font-size:9px;">
                            @(vtxo.IsSpent() ? "SPENT" : "LIVE")
                        </span>
                    </div>

                    @if (_expandedTxId == vtxo.TransactionId)
                    {
                        <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border-subtle);">
                            <div class="detail-row">
                                <span class="detail-label">Transaction ID</span>
                                <div class="address-display" style="font-size:10px;margin-top:4px;">@vtxo.TransactionId</div>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Output Index</span>
                                <span class="detail-value">@vtxo.TransactionOutputIndex</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Amount</span>
                                <span class="detail-value mono">@vtxo.Amount.ToString("N0") sats</span>
                            </div>
                            @if (vtxo.ExpiresAt is not null)
                            {
                                <div class="detail-row">
                                    <span class="detail-label">Expires</span>
                                    <span class="detail-value">@vtxo.ExpiresAt.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </div>
                            }
                            @if (vtxo.CreatedAt != default)
                            {
                                <div class="detail-row">
                                    <span class="detail-label">Created</span>
                                    <span class="detail-value">@vtxo.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </div>
                            }
                            @if (vtxo.Assets is { Count: > 0 })
                            {
                                <div class="detail-row">
                                    <span class="detail-label">Assets</span>
                                    @foreach (var asset in vtxo.Assets)
                                    {
                                        <p class="mono text-secondary" style="font-size:10px;">
                                            @asset.Amount @asset.AssetId[..Math.Min(20, asset.AssetId.Length)]...
                                        </p>
                                    }
                                </div>
                            }
                            <button class="btn btn-sm btn-secondary mt-8" @onclick:stopPropagation="true"
                                    @onclick="@(() => CopyOutpoint(vtxo))">
                                @(_copiedTxId == vtxo.TransactionId ? "Copied!" : "Copy Outpoint")
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private IReadOnlyCollection<ArkVtxo> _vtxos = [];
    private string? _expandedTxId;
    private string? _copiedTxId;
    private string? _filter;

    private IEnumerable<ArkVtxo> FilteredVtxos => _filter switch
    {
        "live" => _vtxos.Where(v => !v.IsSpent()),
        "spent" => _vtxos.Where(v => v.IsSpent()),
        _ => _vtxos
    };

    protected override async Task OnInitializedAsync()
    {
        if (State.ActiveWalletId is not null)
        {
            try { _vtxos = await Ark.GetVtxos(State.ActiveWalletId, take: 500); } catch { }
        }
        _loading = false;
    }

    private void ToggleDetail(string txId)
        => _expandedTxId = _expandedTxId == txId ? null : txId;

    private async Task CopyOutpoint(ArkVtxo vtxo)
    {
        await JS.InvokeVoidAsync("arkade.copyToClipboard", $"{vtxo.TransactionId}:{vtxo.TransactionOutputIndex}");
        _copiedTxId = vtxo.TransactionId;
        StateHasChanged();
        await Task.Delay(2000);
        _copiedTxId = null;
    }
}
