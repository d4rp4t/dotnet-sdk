@page "/receive"
@inject ArkWalletService Ark
@inject WalletState State
@inject IJSRuntime JS
@using NArk.Wallet.Client.Services
@using NArk.Swaps.Boltz
@using Microsoft.AspNetCore.Components

<div class="page-header">
    <a href="./" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <span class="page-title">Receive</span>
</div>

<div class="px-20">
    @if (_loading)
    {
        <div class="flex-col gap-12">
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
        </div>
    }
    else if (_receiveInfo is null)
    {
        <div class="empty-state">
            <p>Create a wallet first to receive funds</p>
        </div>
    }
    else if (_selectedMethod is null)
    {
        <!-- Asset selector -->
        @if (State.TrackedAssetIds.Count > 0)
        {
            <div class="glass-card mb-16" style="padding:12px 14px;">
                <label class="input-label" style="margin-bottom:8px;">Receive Asset</label>
                <select class="input-field" style="padding:10px 12px;font-size:13px;"
                        @onchange="OnAssetChanged">
                    <option value="">BTC (sats)</option>
                    @foreach (var assetId in State.TrackedAssetIds)
                    {
                        <option value="@assetId">@assetId[..Math.Min(20, assetId.Length)]...</option>
                    }
                </select>
            </div>
        }

        @if (_selectedAssetId is null)
        {
            <!-- Amount entry for BTC -->
            <div class="amount-input-row">
                <input type="number" @bind="_amountSats" @bind:event="oninput"
                       placeholder="Amount (optional)" />
                <span class="unit">sats</span>
            </div>

            <p class="text-secondary mb-16" style="font-size:13px;">
                @if (_amountSats > 0)
                {
                    <text>Choose how to receive @_amountSats.ToString("N0") sats</text>
                }
                else
                {
                    <text>Choose how to receive</text>
                }
            </p>
        }
        else
        {
            <p class="text-secondary mb-16" style="font-size:13px;">
                Assets can only be received via Ark address
            </p>
        }

        <!-- Method Cards -->
        <div class="flex-col gap-12">
            <!-- Ark Address (always available) -->
            <div class="method-card ark" @onclick="@(() => SelectMethod("ark"))">
                <div class="method-icon ark">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
                </div>
                <div class="method-info">
                    <div class="method-name">Ark Address</div>
                    <div class="method-desc">Instant, off-chain. Best for Ark-to-Ark.</div>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-tertiary)"><path d="M9 18l6-6-6-6"/></svg>
            </div>

            @if (_selectedAssetId is null)
            {
                @if (_amountSats > 0 && IsWithinReverseLimits())
                {
                    <!-- Lightning (Reverse Swap via Boltz) -->
                    <div class="method-card lightning" @onclick="@(() => SelectMethod("lightning"))">
                        <div class="method-icon lightning">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
                        </div>
                        <div class="method-info">
                            <div class="method-name">Lightning</div>
                            <div class="method-desc">Pay a Lightning invoice to receive into Ark.</div>
                        </div>
                        <span class="pill pill-info" style="font-size:9px;">BOLTZ</span>
                    </div>
                }

                @if (_amountSats > 0 && IsWithinChainLimits())
                {
                    <!-- Chain Swap (BTC on-chain → Ark via Boltz) -->
                    <div class="method-card lightning" @onclick="@(() => SelectMethod("chainswap"))">
                        <div class="method-icon onchain">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
                        </div>
                        <div class="method-info">
                            <div class="method-name">Chain Swap (Boltz)</div>
                            <div class="method-desc">Send BTC on-chain, receive into Ark.</div>
                        </div>
                        <span class="pill pill-info" style="font-size:9px;">BOLTZ</span>
                    </div>
                }

                @if (_amountSats == 0)
                {
                    <div class="method-card lightning" style="opacity:0.5;cursor:default;">
                        <div class="method-icon lightning">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
                        </div>
                        <div class="method-info">
                            <div class="method-name">Lightning / Chain Swap</div>
                            <div class="method-desc">Enter an amount to see swap options</div>
                        </div>
                    </div>
                }

                <!-- Boarding Address -->
                <div class="method-card onchain" @onclick="@(() => SelectMethod("boarding"))">
                    <div class="method-icon onchain">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8M8 12h8"/></svg>
                    </div>
                    <div class="method-info">
                        <div class="method-name">Boarding Address</div>
                        <div class="method-desc">On-chain Bitcoin. Funds enter Ark after confirmation.</div>
                    </div>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-tertiary)"><path d="M9 18l6-6-6-6"/></svg>
                </div>
            }
        </div>

        <!-- Boltz limits footer -->
        @if (_selectedAssetId is null && _boltzLimits is not null)
        {
            <p class="text-secondary mt-16" style="font-size:10px;text-align:center;opacity:0.6;">
                Boltz: @_boltzLimits.ReverseMinAmount.ToString("N0")–@_boltzLimits.ReverseMaxAmount.ToString("N0") sats (LN)@if (_boltzLimits.ChainBtcToArkMinAmount is not null)
                {<text> · @_boltzLimits.ChainBtcToArkMinAmount.Value.ToString("N0")–@_boltzLimits.ChainBtcToArkMaxAmount!.Value.ToString("N0") sats (Chain)</text>}
            </p>
        }
    }
    else if (_initiatingSwap)
    {
        <div class="text-center" style="padding:40px 0;">
            <div class="skeleton" style="width:220px;height:220px;border-radius:20px;margin:0 auto 16px;"></div>
            <p class="text-secondary" style="font-size:14px;">Creating @MethodLabel(_selectedMethod) swap...</p>
        </div>
    }
    else if (_swapError is not null)
    {
        <div class="text-center mb-16">
            <span class="pill pill-danger">ERROR</span>
        </div>
        <div class="glass-card mb-16">
            <p style="color:var(--arkade-red);font-size:13px;">@_swapError</p>
        </div>
        <button class="btn btn-secondary btn-full" @onclick="@(() => { _selectedMethod = null; _swapError = null; })">
            Back
        </button>
    }
    else
    {
        <!-- Step 2: QR + Address Display -->
        <div class="text-center mb-16">
            <span class="pill @MethodPill(_selectedMethod)">
                @MethodLabel(_selectedMethod)
            </span>
        </div>

        <div style="display:flex;justify-content:center;" class="mb-16">
            <div class="qr-container">
                @if (_displayAddress is not null)
                {
                    @((MarkupString)QrCodeHelper.GenerateSvg(_displayAddress))
                }
            </div>
        </div>

        @if (_amountSats > 0 && _selectedAssetId is null)
        {
            <p class="text-center mb-12" style="font-size:14px;font-weight:600;">
                @_amountSats.ToString("N0") <span class="text-secondary" style="font-weight:400;">sats</span>
            </p>
        }

        @if (_selectedAssetId is not null)
        {
            <p class="text-secondary text-center mb-12" style="font-size:12px;">
                Share this Ark address to receive asset <span class="mono">@_selectedAssetId[..Math.Min(16, _selectedAssetId.Length)]...</span>
            </p>
        }
        else if (_selectedMethod == "lightning")
        {
            <p class="text-secondary text-center mb-12" style="font-size:12px;">
                Pay this Lightning invoice to receive sats into your Ark wallet
            </p>
        }
        else if (_selectedMethod == "chainswap")
        {
            <p class="text-secondary text-center mb-12" style="font-size:12px;">
                Send exactly @_chainSwapExpectedSats.ToString("N0") sats to this BTC address
            </p>
        }

        <div class="address-display mb-12">
            @_displayAddress
        </div>

        <!-- Contract Script (for Ark/Boarding) -->
        @if (_displayContractScript is not null)
        {
            <div @onclick="@(() => _showContract = !_showContract)"
                 style="cursor:pointer;margin-bottom:16px;">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;">
                    <span class="text-secondary" style="font-size:11px;font-weight:500;">Contract</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         style="color:var(--text-tertiary);transform:rotate(@(_showContract ? "90" : "0")deg);transition:transform 0.2s;">
                        <path d="M9 18l6-6-6-6"/>
                    </svg>
                </div>
            </div>
            @if (_showContract)
            {
                <div class="address-display mb-16" style="font-size:9px;line-height:1.5;max-height:120px;overflow-y:auto;">
                    @_displayContractScript
                </div>
            }
        }

        <div style="display:flex;gap:8px;">
            <button class="btn btn-primary" style="flex:1;" @onclick="CopyAddress">
                @(_copied ? "Copied!" : _selectedMethod == "lightning" ? "Copy Invoice" : "Copy Address")
            </button>
            <button class="btn btn-secondary" @onclick="@(() => { _selectedMethod = null; _copied = false; _swapError = null; _showContract = false; })">
                Back
            </button>
        </div>
    }
</div>

@code {
    private ArkWalletService.ReceiveInfo? _receiveInfo;
    private string? _selectedMethod;
    private string? _displayAddress;
    private string? _displayContractScript;
    private string? _selectedAssetId;
    private long _amountSats;
    private bool _loading = true;
    private bool _copied;
    private bool _initiatingSwap;
    private bool _showContract;
    private string? _swapError;
    private long _chainSwapExpectedSats;
    private BoltzAllLimits? _boltzLimits;

    protected override async Task OnInitializedAsync()
    {
        if (State.ActiveWalletId is not null)
        {
            try
            {
                var receiveTask = Ark.GetReceiveInfo(State.ActiveWalletId);
                var limitsTask = Ark.GetBoltzLimits();
                await Task.WhenAll(receiveTask, limitsTask);

                _receiveInfo = receiveTask.Result;
                _boltzLimits = limitsTask.Result;
            }
            catch { }
        }
        _loading = false;
    }

    private void OnAssetChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        _selectedAssetId = string.IsNullOrEmpty(val) ? null : val;
    }

    private bool IsWithinReverseLimits()
        => _boltzLimits is not null
           && _amountSats >= _boltzLimits.ReverseMinAmount
           && _amountSats <= _boltzLimits.ReverseMaxAmount;

    private bool IsWithinChainLimits()
        => _boltzLimits?.ChainBtcToArkMinAmount is not null
           && _amountSats >= _boltzLimits.ChainBtcToArkMinAmount
           && _amountSats <= _boltzLimits.ChainBtcToArkMaxAmount;

    private async Task SelectMethod(string method)
    {
        _selectedMethod = method;
        _swapError = null;
        _showContract = false;

        if (method == "lightning")
        {
            _displayContractScript = null;
            await InitiateReverseSwap();
            return;
        }

        if (method == "chainswap")
        {
            _displayContractScript = null;
            await InitiateChainSwap();
            return;
        }

        _displayAddress = method switch
        {
            "ark" => _receiveInfo?.ArkAddress,
            "boarding" => _receiveInfo?.BoardingAddress,
            _ => null
        };

        _displayContractScript = method switch
        {
            "ark" => _receiveInfo?.ArkContractScript,
            "boarding" => _receiveInfo?.BoardingContractScript,
            _ => null
        };
    }

    private async Task InitiateReverseSwap()
    {
        if (State.ActiveWalletId is null) return;
        _initiatingSwap = true;
        StateHasChanged();

        try
        {
            var invoice = await Ark.InitiateReverseSwap(State.ActiveWalletId, _amountSats);
            _displayAddress = invoice;
        }
        catch (Exception ex)
        {
            _swapError = $"Failed to create Lightning invoice: {ex.Message}";
        }
        finally
        {
            _initiatingSwap = false;
        }
    }

    private async Task InitiateChainSwap()
    {
        if (State.ActiveWalletId is null) return;
        _initiatingSwap = true;
        StateHasChanged();

        try
        {
            var (btcAddress, _, expectedSats) = await Ark.InitiateChainSwap(State.ActiveWalletId, _amountSats);
            _displayAddress = btcAddress;
            _chainSwapExpectedSats = expectedSats;
        }
        catch (Exception ex)
        {
            _swapError = $"Failed to create chain swap: {ex.Message}";
        }
        finally
        {
            _initiatingSwap = false;
        }
    }

    private async Task CopyAddress()
    {
        if (_displayAddress is not null)
        {
            await JS.InvokeVoidAsync("arkade.copyToClipboard", _displayAddress);
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
        }
    }

    private static string MethodPill(string? method) => method switch
    {
        "ark" => "pill-info",
        "boarding" => "pill-warning",
        "lightning" => "pill-success",
        "chainswap" => "pill-info",
        _ => "pill-info"
    };

    private static string MethodLabel(string? method) => method switch
    {
        "ark" => "ARK",
        "boarding" => "ON-CHAIN",
        "lightning" => "LIGHTNING",
        "chainswap" => "CHAIN SWAP",
        _ => ""
    };
}
