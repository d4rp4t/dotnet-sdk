@page "/backup"
@inject ArkWalletService Ark
@inject WalletState State
@inject IJSRuntime JS
@using NArk.Wallet.Client.Services
@using NArk.Abstractions.Wallets

<div class="page-header">
    <a href="./settings" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <span class="page-title">Backup</span>
</div>

<div class="px-20">
    @if (_loading)
    {
        <div class="skeleton" style="height:200px;border-radius:14px;"></div>
    }
    else if (_wallet is null)
    {
        <div class="empty-state">
            <p>No wallet found</p>
        </div>
    }
    else if (!_revealed)
    {
        <!-- Pre-reveal warning -->
        <div class="glass-card mb-16" style="border-color:rgba(230,155,57,0.3);">
            <div style="text-align:center;padding:20px 0 12px;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--arkade-orange)" stroke-width="1.5" style="margin-bottom:12px;">
                    <path d="M12 9v4M12 17h.01"/>
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
                <p style="font-size:16px;font-weight:600;margin-bottom:8px;">Your Secret Recovery Phrase</p>
                <p class="text-secondary" style="font-size:13px;line-height:1.6;">
                    This is the <strong>only way</strong> to recover your wallet. Anyone with this
                    phrase can access your funds.
                </p>
            </div>
        </div>

        <div class="glass-card mb-16" style="border-color:rgba(224,82,82,0.2);">
            <div class="flex-col gap-12" style="font-size:13px;">
                <div style="display:flex;gap:10px;align-items:start;">
                    <span style="color:var(--arkade-red);flex-shrink:0;">●</span>
                    <span class="text-secondary">Never share your secret with anyone</span>
                </div>
                <div style="display:flex;gap:10px;align-items:start;">
                    <span style="color:var(--arkade-red);flex-shrink:0;">●</span>
                    <span class="text-secondary">Write it down on paper and store it safely</span>
                </div>
                <div style="display:flex;gap:10px;align-items:start;">
                    <span style="color:var(--arkade-red);flex-shrink:0;">●</span>
                    <span class="text-secondary">Do not take a screenshot</span>
                </div>
            </div>
        </div>

        <button class="btn btn-primary btn-full" @onclick="Reveal">
            I understand, show my secret
        </button>
    }
    else
    {
        <!-- Revealed secret -->
        <div class="text-center mb-16">
            <span class="pill @(_wallet.WalletType == WalletType.HD ? "pill-info" : "pill-warning")">
                @(_wallet.WalletType == WalletType.HD ? "MNEMONIC" : "NSEC")
            </span>
        </div>

        @if (_wallet.WalletType == WalletType.HD)
        {
            <!-- Mnemonic word grid -->
            <div class="mnemonic-grid mb-16">
                @{ var words = _wallet.Secret.Split(' '); }
                @for (int i = 0; i < words.Length; i++)
                {
                    var idx = i;
                    <div class="mnemonic-word">
                        <span class="mnemonic-index">@(idx + 1)</span>
                        <span class="mnemonic-text">@words[idx]</span>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- nsec display -->
            <div class="address-display mb-16" style="font-size:13px;">
                @_wallet.Secret
            </div>
        }

        <div style="display:flex;gap:8px;">
            <button class="btn btn-primary" style="flex:1;" @onclick="CopySecret">
                @(_copied ? "Copied!" : "Copy to Clipboard")
            </button>
            <button class="btn btn-secondary" @onclick="@(() => _revealed = false)">
                Hide
            </button>
        </div>

        <p class="text-secondary text-center mt-16" style="font-size:11px;opacity:0.6;">
            Make sure you've saved this somewhere safe before leaving this page.
        </p>
    }
</div>

@code {
    private ArkWalletInfo? _wallet;
    private bool _loading = true;
    private bool _revealed;
    private bool _copied;

    protected override async Task OnInitializedAsync()
    {
        if (State.ActiveWalletId is not null)
        {
            _wallet = await Ark.GetWalletInfo(State.ActiveWalletId);
        }
        _loading = false;
    }

    private void Reveal() => _revealed = true;

    private async Task CopySecret()
    {
        if (_wallet is null) return;
        await JS.InvokeVoidAsync("arkade.copyToClipboard", _wallet.Secret);
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
    }
}
