@page "/swaps"
@inject ArkWalletService Ark
@inject WalletState State
@inject IJSRuntime JS
@using NArk.Wallet.Client.Services
@using NArk.Swaps.Models

<div class="page-header">
    <a href="./settings" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <span class="page-title">Swaps</span>
</div>

<div class="px-20">
    @if (_loading)
    {
        <div class="flex-col gap-12">
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
            <div class="skeleton" style="height:68px;border-radius:14px;"></div>
        </div>
    }
    else if (_swaps.Count == 0)
    {
        <div class="empty-state">
            <p>No swaps yet</p>
            <p class="text-secondary" style="font-size:12px;">Swaps appear when you use Lightning or chain swap features</p>
        </div>
    }
    else
    {
        <div class="flex-col gap-12">
            @foreach (var swap in _swaps.OrderByDescending(s => s.CreatedAt))
            {
                <div class="glass-card" style="padding:12px 14px;cursor:pointer;" @onclick="@(() => ToggleDetail(swap.SwapId))">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <div style="min-width:0;flex:1;">
                            <div style="display:flex;align-items:center;gap:6px;">
                                <span class="pill @SwapTypePill(swap.SwapType)" style="font-size:8px;">@swap.SwapType</span>
                                <span class="pill @SwapStatusPill(swap.Status)" style="font-size:8px;">@swap.Status</span>
                            </div>
                            <p style="font-size:14px;font-weight:600;font-family:var(--font-mono);margin-top:4px;">
                                @swap.ExpectedAmount.ToString("N0") <span class="text-secondary" style="font-weight:400;font-size:12px;">sats</span>
                            </p>
                        </div>
                        <span class="text-secondary" style="font-size:10px;flex-shrink:0;margin-left:8px;">
                            @swap.CreatedAt.LocalDateTime.ToString("MMM d HH:mm")
                        </span>
                    </div>

                    @if (_expandedId == swap.SwapId)
                    {
                        <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border-subtle);">
                            <div class="detail-row">
                                <span class="detail-label">Swap ID</span>
                                <div class="address-display" style="font-size:10px;margin-top:4px;">@swap.SwapId</div>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Type</span>
                                <span class="detail-value">@swap.SwapType</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Status</span>
                                <span class="detail-value">@swap.Status</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Amount</span>
                                <span class="detail-value mono">@swap.ExpectedAmount.ToString("N0") sats</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(swap.Address))
                            {
                                <div class="detail-row">
                                    <span class="detail-label">Address</span>
                                    <div class="address-display" style="font-size:9px;margin-top:4px;">@swap.Address</div>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(swap.Hash))
                            {
                                <div class="detail-row">
                                    <span class="detail-label">Hash</span>
                                    <p class="mono text-secondary" style="font-size:10px;">@swap.Hash</p>
                                </div>
                            }
                            @if (swap.FailReason is not null)
                            {
                                <div class="detail-row">
                                    <span class="detail-label" style="color:var(--arkade-red);">Fail Reason</span>
                                    <p style="font-size:12px;color:var(--arkade-red);">@swap.FailReason</p>
                                </div>
                            }
                            <div class="detail-row">
                                <span class="detail-label">Created</span>
                                <span class="detail-value">@swap.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Updated</span>
                                <span class="detail-value">@swap.UpdatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </div>
                            @if (swap.Metadata is { Count: > 0 })
                            {
                                <div class="detail-row">
                                    <span class="detail-label">Metadata</span>
                                    @foreach (var kv in swap.Metadata)
                                    {
                                        <p class="mono text-secondary" style="font-size:9px;">@kv.Key: @kv.Value[..Math.Min(60, kv.Value.Length)]@(kv.Value.Length > 60 ? "..." : "")</p>
                                    }
                                </div>
                            }
                            <button class="btn btn-sm btn-secondary mt-8" @onclick:stopPropagation="true"
                                    @onclick="@(() => CopyId(swap.SwapId))">
                                @(_copiedId == swap.SwapId ? "Copied!" : "Copy Swap ID")
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private IReadOnlyCollection<ArkSwap> _swaps = [];
    private string? _expandedId;
    private string? _copiedId;

    protected override async Task OnInitializedAsync()
    {
        if (State.ActiveWalletId is not null)
        {
            try { _swaps = await Ark.GetSwaps(State.ActiveWalletId); } catch { }
        }
        _loading = false;
    }

    private void ToggleDetail(string id)
        => _expandedId = _expandedId == id ? null : id;

    private async Task CopyId(string id)
    {
        await JS.InvokeVoidAsync("arkade.copyToClipboard", id);
        _copiedId = id;
        StateHasChanged();
        await Task.Delay(2000);
        _copiedId = null;
    }

    private static string SwapTypePill(ArkSwapType type) => type switch
    {
        ArkSwapType.ReverseSubmarine => "pill-success",
        ArkSwapType.Submarine => "pill-info",
        ArkSwapType.ChainBtcToArk => "pill-warning",
        ArkSwapType.ChainArkToBtc => "pill-warning",
        _ => "pill-info"
    };

    private static string SwapStatusPill(ArkSwapStatus status) => status switch
    {
        ArkSwapStatus.Pending => "pill-warning",
        ArkSwapStatus.Settled => "pill-success",
        ArkSwapStatus.Failed => "pill-danger",
        ArkSwapStatus.Refunded => "pill-danger",
        _ => "pill-info"
    };
}
