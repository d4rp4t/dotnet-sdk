@page "/settings"
@implements IDisposable
@inject ArkWalletService Ark
@inject WalletState State
@inject IJSRuntime JS
@inject NavigationManager Nav
@using NArk.Wallet.Client.Services
@using NArk.Abstractions.Contracts
@using NArk.Abstractions.VTXOs
@using NArk.Hosting

<div class="page-header">
    <a href="./" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <span class="page-title">Settings</span>
</div>

<div class="px-20">
    @if (_loading)
    {
        <div class="flex-col gap-12">
            <div class="skeleton" style="height:80px;border-radius:14px;"></div>
            <div class="skeleton" style="height:80px;border-radius:14px;"></div>
        </div>
    }
    else if (State.ActiveWalletId is null)
    {
        <div class="empty-state">
            <p>No wallet created yet</p>
        </div>
    }
    else
    {
        <!-- Wallet -->
        <div class="section-header" style="padding:0;">
            <span class="section-title">Wallet</span>
        </div>

        <div class="glass-card mb-16 mt-12">
            <p class="input-label">Wallet ID</p>
            <div class="address-display" style="margin-bottom:8px;">@State.ActiveWalletId</div>
            <button class="btn btn-sm btn-secondary" @onclick="@(() => CopyToClipboard(State.ActiveWalletId!))">
                @(_copiedField == "walletId" ? "Copied!" : "Copy")
            </button>
        </div>

        <!-- Data Pages -->
        <div class="section-header mt-24" style="padding:0;">
            <span class="section-title">Data</span>
        </div>

        <div class="flex-col gap-12 mt-12">
            <a href="./contracts" class="glass-card" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;color:inherit;padding:14px 16px;">
                <div>
                    <p style="font-size:14px;font-weight:600;">Contracts</p>
                    <p class="text-secondary" style="font-size:12px;">@(_contractCount) tracked contracts</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-tertiary);flex-shrink:0;"><path d="M9 18l6-6-6-6"/></svg>
            </a>
            <a href="./vtxos" class="glass-card" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;color:inherit;padding:14px 16px;">
                <div>
                    <p style="font-size:14px;font-weight:600;">VTXOs</p>
                    <p class="text-secondary" style="font-size:12px;">@(_vtxoCount) coins · @(_liveBalance.ToString("N0")) sats live</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-tertiary);flex-shrink:0;"><path d="M9 18l6-6-6-6"/></svg>
            </a>
            <a href="./swaps" class="glass-card" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;color:inherit;padding:14px 16px;">
                <div>
                    <p style="font-size:14px;font-weight:600;">Swaps</p>
                    <p class="text-secondary" style="font-size:12px;">@(_swapCount) swaps</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-tertiary);flex-shrink:0;"><path d="M9 18l6-6-6-6"/></svg>
            </a>
            <a href="./intents" class="glass-card" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;color:inherit;padding:14px 16px;">
                <div>
                    <p style="font-size:14px;font-weight:600;">Intents</p>
                    <p class="text-secondary" style="font-size:12px;">@(_intentCount) intents</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-tertiary);flex-shrink:0;"><path d="M9 18l6-6-6-6"/></svg>
            </a>
        </div>

        <!-- Server Info -->
        @if (_serverNetwork is not null)
        {
            <div class="section-header mt-24" style="padding:0;">
                <span class="section-title">Server</span>
            </div>

            <div class="glass-card mb-16 mt-12">
                <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                    <span class="text-secondary" style="font-size:13px;">Network</span>
                    <span style="font-size:13px;font-weight:500;">@_serverNetwork</span>
                </div>
                @if (_networkConfig is not null)
                {
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                        <span class="text-secondary" style="font-size:13px;">Arkade Server</span>
                        <span class="mono" style="font-size:11px;">@_networkConfig.ArkUri</span>
                    </div>
                    @if (_networkConfig.ArkadeWalletUri is not null)
                    {
                        <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                            <span class="text-secondary" style="font-size:13px;">Delegate Server</span>
                            <span class="mono" style="font-size:11px;">@_networkConfig.ArkadeWalletUri</span>
                        </div>
                    }
                }
                @if (_serverPubkey is not null)
                {
                    <div>
                        <span class="text-secondary" style="font-size:13px;">Server Key</span>
                        <div class="address-display" style="font-size:10px;margin-top:4px;">@_serverPubkey</div>
                    </div>
                }
            </div>
        }

        <!-- Danger Zone -->
        <div class="section-header mt-24" style="padding:0;">
            <span class="section-title" style="color:var(--arkade-red);">Danger Zone</span>
        </div>

        <div class="glass-card mt-12 mb-16" style="border-color:rgba(224,82,82,0.2);">
            <a href="./backup" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;color:inherit;">
                <div>
                    <p style="font-size:14px;font-weight:600;">Backup Secret</p>
                    <p class="text-secondary" style="font-size:12px;">View your recovery phrase or nsec</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-tertiary);flex-shrink:0;"><path d="M9 18l6-6-6-6"/></svg>
            </a>
        </div>

        <div class="glass-card mt-12 mb-24" style="border-color:rgba(224,82,82,0.2);">
            <p class="text-secondary mb-12" style="font-size:12px;">
                Deleting your wallet removes it from this device. Make sure you have backed up your secret.
            </p>
            @if (_confirmDelete)
            {
                <div style="display:flex;gap:8px;">
                    <button class="btn btn-sm" style="background:var(--arkade-red);color:white;flex:1;" @onclick="DeleteWallet">
                        Confirm Delete
                    </button>
                    <button class="btn btn-sm btn-secondary" @onclick="@(() => _confirmDelete = false)">
                        Cancel
                    </button>
                </div>
            }
            else
            {
                <button class="btn btn-sm btn-secondary" style="color:var(--arkade-red);border-color:rgba(224,82,82,0.3);"
                        @onclick="@(() => _confirmDelete = true)">
                    Delete Wallet
                </button>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _serverNetwork;
    private string? _serverPubkey;
    private ArkNetworkConfig? _networkConfig;
    private int _contractCount;
    private int _vtxoCount;
    private long _liveBalance;
    private int _swapCount;
    private int _intentCount;
    private string? _copiedField;
    private bool _confirmDelete;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;

        if (State.ActiveWalletId is not null)
        {
            try
            {
                var vtxoTask = Ark.GetVtxos(State.ActiveWalletId, take: 500);
                var serverTask = Ark.GetServerInfo();
                var contractsTask = Ark.GetContracts(State.ActiveWalletId, take: 500);
                var swapsTask = Ark.GetSwaps(State.ActiveWalletId);
                var intentsTask = Ark.GetIntents(State.ActiveWalletId, take: 500);

                await Task.WhenAll(vtxoTask, serverTask, contractsTask, swapsTask, intentsTask);

                var vtxos = vtxoTask.Result;
                _vtxoCount = vtxos.Count;
                _liveBalance = (long)vtxos.Where(v => !v.IsSpent()).Aggregate(0UL, (sum, v) => sum + v.Amount);
                _contractCount = contractsTask.Result.Count;
                _swapCount = swapsTask.Result.Count;
                _intentCount = intentsTask.Result.Count;

                var info = serverTask.Result;
                _serverNetwork = info.Network?.Name ?? "Unknown";
                _serverPubkey = info.SignerKey?.ToString();
                _networkConfig = Ark.GetNetworkConfig();
            }
            catch { }
        }
        _loading = false;
    }

    private async Task CopyToClipboard(string text, string? field = null)
    {
        await JS.InvokeVoidAsync("arkade.copyToClipboard", text);
        _copiedField = field ?? "walletId";
        StateHasChanged();
        await Task.Delay(2000);
        _copiedField = null;
    }

    private async Task DeleteWallet()
    {
        if (State.ActiveWalletId is not null)
        {
            await Ark.DeleteWallet(State.ActiveWalletId);
            State.SetActiveWallet(null);
            _confirmDelete = false;
        }
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
